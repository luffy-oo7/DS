from dateutil import parser
import socket, threading, datetime, time

clients = {}

def handle(conn, addr):
    while True:
        try:
            data = conn.recv(1024).decode()
            if not data:
                break
            t = parser.parse(data)
            diff = datetime.datetime.now() - t
            clients[addr] = (conn, diff)
            print("Client Data updated:", addr)
        except:
            break
    if addr in clients:
        del clients[addr]
    print(addr, "disconnected")


def sync():
    while True:
        print("\nNew synchronization cycle")
        print("Clients:", len(clients))
        if clients:
            avg = sum([c[1] for c in clients.values()], datetime.timedelta()) / len(clients)
            
            for addr, (conn, d) in list(clients.items()):
                try:
                    offset = (avg - d).total_seconds()
                    conn.send(str(offset).encode())
                except:
                    pass
        time.sleep(5)


s = socket.socket()
s.bind(('', 8080))
s.listen()

print("Server started.jodd..\n")

threading.Thread(target=sync, daemon=True).start()

while True:
    conn, addr = s.accept()
    print(f"{addr[0]}:{addr[1]} connected")
    threading.Thread(target=handle, args=(conn, addr), daemon=True).start()


