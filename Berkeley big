from dateutil import parser
import socket, threading, datetime, time
offset = datetime.timedelta(0)
def send(c):
    while True:
        try:
            c.send(str(datetime.datetime.now()+offset).encode())
            print("Time sent")
            time.sleep(5)
        except:
            break


def receive(c):
    global offset
    while True:
        try:
            data = c.recv(1024).decode()
            if not data:
                break

            correction = float(data)
            offset += datetime.timedelta(seconds=correction)

            print("Offset updated:", offset)

        except:
            break


c = socket.socket()
c.connect(('127.0.0.1', 8080))

threading.Thread(target=send, args=(c,), daemon=True).start()
threading.Thread(target=receive, args=(c,), daemon=True).start()

while True:
    time.sleep(1)


